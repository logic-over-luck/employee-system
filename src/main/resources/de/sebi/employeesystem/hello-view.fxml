<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="de.sebi.employeesystem.HelloController"
            prefWidth="820" prefHeight="600">

    <!-- ── Header ── -->
    <top>
        <HBox style="-fx-background-color: #2c3e50; -fx-padding: 14 20 14 20;"
              alignment="CENTER_LEFT" spacing="12">
            <Label text="👥  Mitarbeiterverwaltung"
                   style="-fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: bold;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="＋  Neuer Mitarbeiter" onAction="#onNewEmployeeClick"
                    style="-fx-background-color: #27ae60; -fx-text-fill: white;
                           -fx-font-weight: bold; -fx-cursor: hand; -fx-padding: 7 14 7 14;"/>
        </HBox>
    </top>

    <!-- ── Inhalt ── -->
    <center>
        <VBox spacing="12" style="-fx-padding: 16; -fx-background-color: #f0f2f5;">

            <!-- Suchleiste -->
            <HBox spacing="8" alignment="CENTER_LEFT">
                <TextField fx:id="txtSearch"
                           promptText="🔍  Nach Name, Position oder E-Mail suchen …"
                           HBox.hgrow="ALWAYS" maxWidth="Infinity"
                           onAction="#onSearchClick"/>
                <Button text="Suchen" onAction="#onSearchClick"
                        style="-fx-background-color: #3498db; -fx-text-fill: white;
                               -fx-cursor: hand; -fx-padding: 6 14 6 14;"/>
                <Button text="Zurücksetzen" onAction="#onLoadDataButtonClick"
                        style="-fx-background-color: #7f8c8d; -fx-text-fill: white;
                               -fx-cursor: hand; -fx-padding: 6 14 6 14;"/>
            </HBox>

            <!-- Tabelle — Doppelklick öffnet Profil -->
            <TableView fx:id="employeeTable" VBox.vgrow="ALWAYS"
                       style="-fx-background-color: white; -fx-border-color: #dcdcdc;">
                <columns>
                    <TableColumn fx:id="colId"        text="ID"       prefWidth="55"/>
                    <TableColumn fx:id="colFirstName" text="Vorname"  prefWidth="150"/>
                    <TableColumn fx:id="colLastName"  text="Nachname" prefWidth="160"/>
                    <TableColumn fx:id="colPosition"  text="Position" prefWidth="130"/>
                    <TableColumn fx:id="colActive"    text="Status"   prefWidth="100"/>
                </columns>
                <placeholder>
                    <Label text="Keine Mitarbeiter gefunden."
                           style="-fx-text-fill: #aaaaaa; -fx-font-size: 13px;"/>
                </placeholder>
            </TableView>

            <!-- Pagination + Status -->
            <HBox spacing="12" alignment="CENTER_LEFT">
                <Label fx:id="lblStatus" text="Bereit."
                       style="-fx-text-fill: #555; -fx-font-size: 12px;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button fx:id="btnPrev" text="◀  Zurück" onAction="#onPrevPageClick"
                        disable="true" style="-fx-cursor: hand;"/>
                <Label fx:id="lblPage" text="Seite 1 / 1" style="-fx-font-weight: bold;"/>
                <Button fx:id="btnNext" text="Weiter  ▶" onAction="#onNextPageClick"
                        style="-fx-cursor: hand;"/>
            </HBox>

        </VBox>
    </center>

</BorderPane>
